# =============================================================================
# Django
# =============================================================================
SECRET_KEY=change-me-to-a-long-random-string
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# =============================================================================
# Database (Django)
# DB_HOST=db when using docker-compose; use your DB host in production
# =============================================================================
DB_ENGINE=django.contrib.gis.db.backends.postgis
DB_NAME=fitness_db
DB_USER=postgres
DB_PASSWORD=change-me
DB_HOST=db
DB_PORT=5432

# =============================================================================
# PostgreSQL container (docker-compose db service — must match DB_* above)
# =============================================================================
POSTGRES_DB=fitness_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me

# =============================================================================
# JWT
# =============================================================================
SIMPLE_JWT_ACCESS_DAYS=10
SIMPLE_JWT_REFRESH_DAYS=30

# =============================================================================
# CORS & CSRF
# Production: set DEBUG=False, CORS_ALLOW_ALL_ORIGINS=False, and list origins
# =============================================================================
# Production example:
# DEBUG=False
# ALLOWED_HOSTS=fitness.runflare.run,fit-ticket.runflare.run
# CORS_ALLOW_ALL_ORIGINS=False
# CORS_ALLOWED_ORIGINS=https://fitness.runflare.run,https://fit-ticket.runflare.run
# CSRF_TRUSTED_ORIGINS=https://fitness.runflare.run,https://fit-ticket.runflare.run
# CSRF_COOKIE_SECURE=True
# SESSION_COOKIE_SECURE=True
CORS_ALLOW_ALL_ORIGINS=True
CORS_ALLOWED_ORIGINS=
CSRF_TRUSTED_ORIGINS=http://localhost:8000
CSRF_COOKIE_SECURE=False
SESSION_COOKIE_SECURE=False

# =============================================================================
# Melipayamak SMS
# =============================================================================
MELIPAYAMAK_API_KEY=your-api-key
MELIPAYAMAK_USERNAME=your-username
MELIPAYAMAK_PASSWORD=your-password
MELIPAYAMAK_FROM=50002710016357

# =============================================================================
# Payment gateway
# =============================================================================
PAYMENT_GATEWAY_MERCHANT_ID=76e2de0d-8d61-418e-866a-2554cb9e4178
PAYMENT_GATEWAY_SANDBOX=False
PAYMENT_GATEWAY_SUCCESS_REDIRECT_URL=
PAYMENT_GATEWAY_FAILURE_REDIRECT_URL=
